VITE_API_URL=http://localhost:8000

VITE_MAPBOX_TOKEN=__PEGAR_TOKEN_AQUI__
VITE_WS_URL=ws://localhost:8765

# Bypass total de autenticación. Cuando es "true", la app inyecta un usuario mock
# con todos los permisos y NO llama al backend para validar sesión.
# PELIGRO: si esto queda "true" en producción, cualquiera tiene acceso total.
VITE_BYPASS_AUTH=false
